PORT=8080
PUBLIC_APP_URL=http://localhost:5173

# Production database. Required before live deployment.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/kalpavriksha_ops
DB_SSL=false

# Email OTP provider: local, smtp, gmail, resend, sendgrid, brevo
# local lets OTP work during testing even if Gmail credentials are rejected. Use real provider before production.
# Recommended free/easy option: gmail with a Google App Password
EMAIL_PROVIDER=local
OTP_FROM_EMAIL=your-email@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-google-app-password
RESEND_API_KEY=
SENDGRID_API_KEY=
BREVO_API_KEY=

# Optional SMS OTP provider: twilio, fast2sms, msg91
SMS_PROVIDER=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
FAST2SMS_API_KEY=
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_SENDER_ID=

# Keep true for localhost testing only. Set false in production.
ALLOW_LOCAL_EMAIL_OTP=true
# EMAIL_USER/EMAIL_PASS aliases are also supported for Gmail SMTP.
EMAIL_USER=
EMAIL_PASS=
