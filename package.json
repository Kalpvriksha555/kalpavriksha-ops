{
  "name": "kalpavriksha-designs-ops",
  "version": "1.0.0-production-candidate",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "smoke": "node scripts/smoke-check.mjs",
    "dev:backend": "cd backend && npm run dev",
    "dev:all": "node scripts/start-all.mjs",
    "start": "vite --host 0.0.0.0",
    "serve": "vite preview --host 0.0.0.0",
    "prod": "npm run build && npm run serve",
    "preflight": "node scripts/preflight.mjs",
    "db:health": "node backend/scripts/db-health.mjs",
    "go-live:check": "npm run build && npm run smoke && npm run db:health"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "firebase": "latest",
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "autoprefixer": "^10.4.21",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.17"
  }
}